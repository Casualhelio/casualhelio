# HTTP headers for Netlify & Cloudflare Pages (static hosting).
# These set the security headers that CANNOT be set via <meta> in HTML
# (clickjacking / nosniff / HSTS) plus sensible caching.

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  Cross-Origin-Opener-Policy: same-origin
  X-Permitted-Cross-Domain-Policies: none
  Content-Security-Policy: default-src 'self'; script-src 'self' https://web3forms.com https://hcaptcha.com https://*.hcaptcha.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://cdn.sanity.io; connect-src 'self' https://ka04oafk.api.sanity.io https://mongolian-bank-exchange-rate-6620c122ff22.herokuapp.com https://cdn.moneyconvert.net https://api.web3forms.com https://hcaptcha.com https://*.hcaptcha.com; frame-src https://maps.google.com https://www.google.com https://hcaptcha.com https://*.hcaptcha.com; media-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self' https://api.web3forms.com; frame-ancestors 'none'; upgrade-insecure-requests

# Versioned CSS/JS (cache-busted with ?v=NN) — safe to cache for a week.
/css/*
  Cache-Control: public, max-age=604800
/js/*
  Cache-Control: public, max-age=604800

# Images / video / pdf — replaced in place occasionally, so cache 1 day.
/assets/*
  Cache-Control: public, max-age=86400

# HTML must always re-validate so content/version updates appear immediately.
/*.html
  Cache-Control: public, max-age=0, must-revalidate
